# Backend configuration file. Copy this to .env and fill in the values before running the server.

# Flask
FLASK_ENV=development
PORT=8080
DEBUG=True
SECRET_KEY=change-me-in-production

# MongoDB
URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority

# Supabase (auth only)
SUPABASE_URL=https://<project-ref>.supabase.co

# OpenAI (optional — falls back to Ollama if unset)
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_BASE_URL=openai-base-url

# Ollama (fallback LLM when OPENAI_API_KEY is empty)
OLLAMA_BASE_URL=http://localhost:11434

# Pinecone (vector search)
PINECONE_API_KEY=your-pinecone-api-key-here

# Google Maps (location tools)
GOOGLE_MAPS_API_KEY=your-google-maps-api-key-here

# RapidAPI (listing ingestion scripts only)
RAPIDAPI_KEY=your-rapidapi-key-here
